# Copy this file to .env and fill in the values
# Never commit .env to version control

# --- Backend ---
# Number of uvicorn worker processes
WORKERS=2

# Allowed CORS origins (comma-separated).
# Use the frontend origin in production. Use * only during local development.
CORS_ORIGINS=http://localhost:3000

# Max file upload size in bytes (default: 100 MB)
MAX_UPLOAD_BYTES=104857600

# Directory for uploaded and processed files (inside the container)
UPLOAD_DIR=/app/uploads

# --- Ports (host:container) – used by docker-compose only ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
